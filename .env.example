# ─── OddFeed — Variabili d'ambiente ───────────────────────────────────────────
# Copia questo file in .env e compila i valori reali.
# Il file .env NON deve essere committato su Git (già in .gitignore).

# ── Firebase (usato dagli script Node.js in /scripts) ──────────────────────────
# Percorso al file JSON della service account Firebase Admin
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Oppure, per GitHub Actions / ambienti cloud: JSON inline come variabile
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":...}

# ── OpenAI (GPT-4o mini per riscrivere le notizie) ────────────────────────────
OPENAI_KEY=sk-...

# ── The Guardian API (sorgente notizie) ───────────────────────────────────────
GUARDIAN_KEY=...

# ── RevenueCat ────────────────────────────────────────────────────────────────
# Chiave iOS: recuperala da app.revenuecat.com → Apps → OddFeed iOS → API Keys
REVENUECAT_API_KEY_IOS=appl_AafGysRfSpUijqgyWqsRxZihzcM

# Chiave Android: recuperala da app.revenuecat.com → Apps → OddFeed Android → API Keys
REVENUECAT_API_KEY_ANDROID=goog_...

# ── EAS / Expo ────────────────────────────────────────────────────────────────
# Account Expo (slug dell'owner)
EXPO_ACCOUNT=lakida

# ── Apple (per eas submit) ────────────────────────────────────────────────────
# Apple ID dell'account developer
APPLE_ID=kida.mancinimesi@gmail.com

# App Store Connect App ID (trovalo in App Store Connect → App → General → App Information)
ASC_APP_ID=

# Apple Team ID (trovalo su developer.apple.com → Account → Membership)
APPLE_TEAM_ID=

# ── Google Play (per eas submit Android) ──────────────────────────────────────
# Percorso al JSON della service account Google Play Console
# Vedi: https://github.com/expo/fyi/blob/main/creating-google-service-account.md
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account-play.json
