{
  "expo": {
    "name": "OddFeed",
    "slug": "OddFeed",
    "version": "1.0.0",
    "scheme": "oddfeed",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oddfeed.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:oddfeed.app"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "package": "com.oddfeed.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "https", "host": "oddfeed.app", "pathPrefix": "/articolo" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "skAdNetworkItems": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.272354842276-php917dld6bdhvii5v88i2gmigk8bq4b"
        }
      ],
      [
        "react-native-fbsdk-next",
        {
          "appID": "2715352588826470",
          "clientToken": "fd326ac310a3d7351cb0753d6ad88edf",
          "displayName": "OddFeed",
          "scheme": "fb2715352588826470",
          "advertiserIDCollectionEnabled": false,
          "autoLogAppEventsEnabled": false,
          "isAutoInitEnabled": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "18a2437f-f82a-46ce-a760-1f7228f71f6a"
      }
    },
    "owner": "lakida"
  }
}
